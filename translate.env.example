# Copy this to `translate.env` to enable the Translate button (OCR + translate
# via an Ollama OpenAI-compatible vision model). Read at BUILD time by build.rs
# and baked into the binary, so rebuild after editing. If `translate.env` is
# absent, translation is disabled and the button is hidden.

base_url=http://192.168.1.179:11434/v1
model=qwen3.6:35b
api_key=ollama
